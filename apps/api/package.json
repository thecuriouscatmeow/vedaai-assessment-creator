{
  "name": "@vedaai/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "VedaAI backend — Express + TS API and BullMQ worker.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "worker": "tsx watch src/worker.ts",
    "start:worker": "tsx src/worker.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/google-genai": "^2.1.31",
    "@vedaai/shared": "workspace:*",
    "bullmq": "^5.77.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "langchain": "^1.4.2",
    "mongoose": "^9.6.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "socket.io": "^4.8.3",
    "unpdf": "^1.6.2",
    "xss": "^1.0.15",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/supertest": "^6.0.3",
    "mongodb-memory-server": "^11.1.0",
    "pino-pretty": "^13.1.3",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
