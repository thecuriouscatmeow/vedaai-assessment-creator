#!/usr/bin/env bash
# CodeRabbit per-commit review (coderabbit CLI — plain text output)
# Runs automatically after every `git commit`.
# Advisory only — exits 0 regardless of findings so commits are never blocked.

set -euo pipefail

# ── Guard: CR must be installed ────────────────────────────────────────────────
if ! command -v coderabbit &>/dev/null; then
  echo "⚠  coderabbit not found — skipping review (run: npm i -g @coderabbit/coderabbit-cli)"
  exit 0
fi

echo ""
echo "🐇 CodeRabbit review — HEAD"
echo "──────────────────────────────────────────"

# Plain-text review of committed changes only.
# On the very first commit HEAD~1 does not exist; omit --base-commit.
if git rev-parse --verify HEAD~1 &>/dev/null; then
  coderabbit review --plain -t committed --base-commit HEAD~1 || {
    echo "⚠  coderabbit review exited with an error — check your CR config/token."
  }
else
  coderabbit review --plain -t committed || {
    echo "⚠  coderabbit review exited with an error — check your CR config/token."
  }
fi

echo "──────────────────────────────────────────"
echo ""

exit 0
