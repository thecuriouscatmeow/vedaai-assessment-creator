# Copy to `.env` and fill in. The api validates these at boot (fails fast).

# Runtime
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Datastores
MONGODB_URI=mongodb://localhost:27017/vedaai
REDIS_URL=redis://localhost:6379

# LLM (Gemini is the committed/default provider)
GEMINI_API_KEY=your-gemini-api-key

# Cloudinary (signed uploads — frontend uploads directly, backend stores URL only)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Socket.IO CORS — set to the web origin (default: http://localhost:3000)
WEB_ORIGIN=http://localhost:3000

# --- Web (apps/web) ---
# Copy to apps/web/.env.local for local development
NEXT_PUBLIC_API_URL=http://localhost:4000
