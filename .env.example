# Copy to apps/api/.env and fill in real values.
# The API validates every variable at boot and fails fast on missing/invalid ones.

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | test | production
PORT=4000
LOG_LEVEL=info                # trace | debug | info | warn | error

# ── Datastores ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/vedaai   # Atlas URI in staging/prod
REDIS_URL=redis://localhost:6379              # Railway Redis URL in staging/prod

# ── AI / LLM ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key            # Google AI Studio → API keys

# ── File Storage (Cloudinary) ─────────────────────────────────────────────────
# Frontend uploads directly (signed); backend stores the resulting URL only.
# NOTE: CLOUDINARY_URL is auto-injected by Railway's Cloudinary add-on and is
# intentionally absent from the Zod schema — the three individual vars below
# are the source of truth and are what loadConfig() validates.  Do not add
# CLOUDINARY_URL to config.ts; it is redundant with the three vars below.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ── CORS / Origins ────────────────────────────────────────────────────────────
WEB_ORIGIN=http://localhost:3000              # Vercel URL in staging/prod

# ── Web (apps/web) ────────────────────────────────────────────────────────────
# Copy to apps/web/.env.local for local development.
NEXT_PUBLIC_API_URL=http://localhost:4000     # Railway API URL in staging/prod
